rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lowercased email of the requesting user, or '' if none.
    function email() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    // A user's own data tree: users/{uid}/{collection}/{docId}
    match /users/{uid} {
      // The top-level user doc (optional profile summary).
      allow read: if request.auth != null &&
        (request.auth.uid == uid ||
         exists(/databases/$(database)/documents/users/$(uid)/viewers/$(email())));
      allow write: if request.auth != null && request.auth.uid == uid;

      // Grants: owner lists people they've shared with, keyed by viewer email.
      match /viewers/{viewerEmail} {
        allow read: if request.auth != null &&
          (request.auth.uid == uid || viewerEmail == email());
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // All study data. Owner has full access; granted viewers read-only.
      match /{collection}/{docId} {
        allow read: if request.auth != null &&
          (request.auth.uid == uid ||
           exists(/databases/$(database)/documents/users/$(uid)/viewers/$(email())));
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Discovery index for viewers: shares/{viewerEmail}/from/{ownerUid}
    // Lets a viewer list who has shared with them, and lets an owner
    // create/remove their own entry in someone's index.
    match /shares/{viewerEmail}/from/{ownerUid} {
      allow read: if request.auth != null && viewerEmail == email();
      allow write: if request.auth != null && request.auth.uid == ownerUid;
    }
  }
}
